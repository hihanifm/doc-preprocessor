# Optional — copy to .env for local overrides.

# Server log verbosity (DEBUG, INFO, WARNING, …). Default INFO if unset.
# LOG_LEVEL=INFO

# LLM chat: use OpenAI-style streaming (SSE) for /v1/chat/completions. Default on. Set 0 to force one-shot JSON only.
# LLM_STREAM=1

# Support inbox for "Save for developer". Defaults to ./support_uploads next to app.py
# when unset or when no .env exists. Override with an absolute path or another folder name.
# SUPPORT_UPLOAD_DIR=support_uploads

# LLM extraction uses the browser form only (base URL, API key, model) — nothing stored here.
