# Optional — copy to .env for local overrides.

# Server log verbosity (DEBUG, INFO, WARNING, …). Default INFO if unset.
# LOG_LEVEL=INFO

# LLM chat: use OpenAI-style streaming (SSE) for /v1/chat/completions (whole-file extract when UI is Auto). Default on.
# LLM_STREAM=1
# Section-by-section extract: default off (many sequential requests). Set 1 to stream each section too.
# LLM_STREAM_SECTIONS=0

# Max chat/completions calls per fixed 60s window (process-wide). After 3 calls, wait until the window
# ends, then the counter resets to 0 and the next 3 may run back-to-back. 0 = unlimited.
# LLM_RPM=3

# Optional: append full LLM request/response JSON to this file (Authorization header redacted). Relative paths are from the project root.
# LLM_IO_LOG_PATH=llm_io.log

# Support inbox for "Save for developer". Defaults to ./support_uploads next to app.py
# when unset or when no .env exists. Override with an absolute path or another folder name.
# SUPPORT_UPLOAD_DIR=support_uploads

# LLM extraction uses the browser form only (base URL, API key, model) — nothing stored here.
